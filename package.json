{
  "name": "iam",
  "version": "0.2.3",
  "description": "Small IAM authentication, authorization, and session library for JavaScript.",
  "type": "module",
  "main": "./src/index.js",
  "types": "./src/index.d.ts",
  "exports": {
    ".": {
      "types": "./src/index.d.ts",
      "import": "./src/index.js"
    },
    "./adapters": {
      "types": "./src/adapters/index.d.ts",
      "import": "./src/adapters/index.js"
    },
    "./express": {
      "types": "./src/express/index.d.ts",
      "import": "./src/express/index.js"
    },
    "./browser": {
      "types": "./src/browser/index.d.ts",
      "import": "./src/browser/index.js"
    }
  },
  "scripts": {
    "example:sqlite": "node examples/sqlite.js",
    "test": "node --test"
  },
  "keywords": [
    "iam",
    "rbac",
    "auth",
    "authorization",
    "sessions"
  ],
  "license": "MIT",
  "dependencies": {
    "jose": "^6.2.3"
  },
  "devDependencies": {
    "better-sqlite3": "^12.11.1",
    "seq": "github:acmepy/seq"
  }
}
